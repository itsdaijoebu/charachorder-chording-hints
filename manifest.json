{
  "manifest_version": 3,
  "name": "Chording Hints",
  "version": "1.0.0",
  "description": "Shows chord hints for CCOS devices like the CharaChorder on typing training sites to help learn chording libraries faster.",
  "permissions": ["storage"],
  "host_permissions": ["https://entertrained.app/prompt/*"],
  "web_accessible_resources": [
    {
      "resources": ["icons/*.svg"],
      "matches": ["https://entertrained.app/*"]
    }
  ],
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://entertrained.app/prompt/*"],
      "js": ["shared.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Entertrained Charachorder Hints",
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icons/cch-icon-128.png"
    }
  }
}