{
  "manifest_version": 3,
  "name": "Entertrained Charachorder Hints",
  "version": "0.3.1",
  "description": "Shows Charachorder chord hints above words on Entertrained typing practice pages.",
  "permissions": ["storage"],
  "host_permissions": ["https://entertrained.app/prompt/*"],
  "web_accessible_resources": [
    {
      "resources": ["icons/*.svg"],
      "matches": ["https://entertrained.app/*"]
    }
  ],
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://entertrained.app/prompt/*"],
      "js": ["shared.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Entertrained Charachorder Hints"
  }
}
